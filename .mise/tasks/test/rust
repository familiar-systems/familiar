#!/usr/bin/env bash
#MISE description="Run Rust tests"
#MISE sources=["apps/platform/**/*.rs", "apps/campaign/**/*.rs", "crates/**/*.rs", "Cargo.toml", "Cargo.lock", "apps/platform/Cargo.toml", "apps/campaign/Cargo.toml", "crates/**/Cargo.toml"]
set -euo pipefail

# ts-rs's #[ts(export)] derive expands into #[cfg(test)] functions that write
# .ts files as a side effect. Redirect those writes to a temp directory so
# plain test runs don't mutate (or require) the packages/ tree.
export TS_RS_EXPORT_DIR
TS_RS_EXPORT_DIR="$(mktemp -d)"
trap 'rm -rf "$TS_RS_EXPORT_DIR"' EXIT

cargo test --workspace --locked
