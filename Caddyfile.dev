# Local-dev reverse proxy that mirrors the prod URL contract.
#
# Run via `mise run dev:proxy` alongside `mise run dev`. Opens two hosts
# on port 8080 - a marketing apex and an app apex - matching the two-apex
# split used in preview and prod:
#
#   http://localhost:8080                 -> Astro marketing site (port 4321)
#   http://app.localhost:8080/            -> Vite SPA at root (port 5173)
#   http://app.localhost:8080/api/*       -> platform server (port 3000)
#   http://app.localhost:8080/campaign/*  -> campaign server (port 3001)
#   http://app.localhost:8080/catalog/*   -> campaign server (port 3001)
#
# /catalog/* is its own prefix (not nested under /campaign/) because the
# catalog endpoint is campaign-tier-stateless: any shard can answer it,
# round-robin in prod. In local dev there is one shard, so it's a degenerate
# case, but keeping the path shape consistent with prod prevents drift.
#
# Why two hosts: the marketing site and the app must live on different
# browser origins so that cookie / localStorage scope, CORS, and Hanko's
# registered-origin contract all match what preview and prod enforce.
# Running them on one localhost port hid that boundary and produced
# dev/prod drift that only surfaced in deployment.
#
# Why *.localhost: modern browsers (Chrome/Firefox/Safari) treat any
# *.localhost name as loopback by convention - no /etc/hosts entries,
# no dnsmasq. Caddy serves both host matchers from a single :8080 bind.
#
# WebSockets (Vite HMR, Astro HMR, campaign-server Loro sync) upgrade
# automatically through `reverse_proxy` in Caddy v2; no ws: true flag.

# `http://` prefix is load-bearing: without it, Caddy sees a hostname+non-
# standard-port address (`localhost:8080`) and engages auto-HTTPS - it tries
# to install its local CA, issue a cert, and serve TLS on 8080, which
# (a) prompts for sudo on the first run and (b) breaks plain-HTTP curls.
# Forcing `http://` makes Caddy listen on 8080 as unencrypted HTTP, which is
# what we want for localhost dev. TLS in prod is Traefik's job.

http://localhost:8080 {
	# Marketing: the Astro static site. No authenticated surfaces live here.
	reverse_proxy localhost:4321
}

http://app.localhost:8080 {
	# Platform API: strip /api so the backend sees /me, /health, etc.
	handle_path /api/* {
		reverse_proxy localhost:3000
	}

	# Campaign shards: forward with /campaign prefix intact so the binary
	# sees /campaign/<id>/initialize, /campaign/<id>/ws, etc.
	handle /campaign/* {
		reverse_proxy localhost:3001
	}

	# Catalog: campaign-tier route, forward with /catalog prefix intact so
	# the binary sees /catalog/systems. Same upstream as /campaign/*;
	# stateless across shards in prod.
	handle /catalog/* {
		reverse_proxy localhost:3001
	}

	# SPA catch-all. Vite is built with base=/ on this apex, so it receives
	# URLs as-is. This handler is last because the handle_path blocks above
	# match longer prefixes first.
	handle {
		reverse_proxy localhost:5173
	}
}
