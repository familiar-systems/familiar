---
import { useTranslations } from '~/i18n/utils';
import Section from '~/components/layout/Section.astro';
import LatestPosts from '~/components/sections/LatestPosts.astro';
import Button from '~/components/ui/Button.astro';
import NewsletterSignup from '~/components/common/NewsletterSignup.astro';
import { BookOpen, Upload, Sparkles, CheckCircle, ScrollText, MapPin, Users, Swords, Link2, Eye, Clock, MessageSquare, ShieldCheck, GitFork } from 'lucide-react';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

  <!-- ═══════════════════════════════════════════ -->
  <!-- HERO                                        -->
  <!-- ═══════════════════════════════════════════ -->
  <section class="min-h-[90vh] flex items-center justify-center relative overflow-hidden pt-20 bg-background">
    <!-- Frost on the edges (the cold outside) -->
    <div class="absolute inset-0 z-0 pointer-events-none frost-edges"></div>

    <!-- Warm hearth glow (dominant, flickering) -->
    <div class="absolute inset-0 z-0 hearth-flicker">
      <div class="absolute top-[20%] left-1/2 -translate-x-1/2 w-[800px] h-[600px] rounded-full blur-[180px] fire-core"></div>
      <div class="absolute top-[30%] left-[42%] w-[500px] h-[450px] rounded-full blur-[140px] fire-secondary"></div>
      <div class="absolute top-[40%] left-[55%] w-[300px] h-[300px] rounded-full blur-[100px] fire-accent"></div>
    </div>

    <!-- Ember particles -->
    <div class="absolute inset-0 z-0 ember-field overflow-hidden"></div>

    <div class="container mx-auto px-6 relative z-10 text-center">
      <div class="hero-content opacity-0 translate-y-5">
        <p class="inline-block text-sm font-medium tracking-[0.2em] uppercase text-primary mb-8 border border-primary/30 rounded-full px-5 py-2 bg-primary/5 dark:bg-primary/10">
          {t['hero.badge']}
        </p>
        <h1 class="font-display text-5xl md:text-7xl lg:text-8xl font-bold tracking-tight mb-8 text-foreground leading-[1.1]">
          {t['hero.title']}<br />
          <span class="text-primary">{t['hero.highlight']}</span>
        </h1>
        <p class="text-xl md:text-2xl text-muted-foreground max-w-2xl mx-auto mb-12 leading-relaxed">
          {t['hero.subtitle']}
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
          <Button
            href={`/${lang}/blog/2026-02-20-the-vision`}
            class="px-8 py-4 rounded-full text-base"
          >
            {t['hero.getStarted']}
          </Button>
          <Button
            href="https://github.com/loreweaver-no"
            variant="secondary"
            class="px-8 py-4 rounded-full text-base backdrop-blur-sm"
            target="_blank"
            rel="noopener noreferrer"
          >
            {t['hero.learnMore']}
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════ -->
  <!-- THE CORE LOOP                               -->
  <!-- ═══════════════════════════════════════════ -->
  <Section class="py-24 md:py-32">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-display text-3xl md:text-4xl font-bold text-center mb-4">After Every Session</h2>
      <p class="text-center text-muted-foreground text-lg mb-16 max-w-2xl mx-auto">
        The core loop takes 15 minutes, not hours. You played the game - let the AI do the bookkeeping.
      </p>

      <div class="relative">
        <!-- Vertical connector line (warm ember) -->
        <div class="absolute left-8 md:left-10 top-0 bottom-0 w-px hidden md:block" style="background: linear-gradient(to bottom, rgba(224, 122, 58, 0), rgba(224, 122, 58, 0.3) 15%, rgba(224, 122, 58, 0.3) 85%, rgba(224, 122, 58, 0));"></div>

        <div class="space-y-12">
          <!-- Step 1 -->
          <div class="flex gap-6 md:gap-8 items-start group">
            <div class="relative z-10 w-16 h-16 md:w-20 md:h-20 rounded-2xl bg-primary/10 dark:bg-primary/5 border border-primary/20 flex items-center justify-center shrink-0 group-hover:bg-primary/20 transition-colors duration-300">
              <Upload className="w-7 h-7 md:w-8 md:h-8 text-primary" />
            </div>
            <div class="pt-2 md:pt-4">
              <h3 class="text-xl font-bold mb-2">Upload your recording or notes</h3>
              <p class="text-muted-foreground leading-relaxed">Audio, video, or written notes from the session. Players can add their characters' perspectives too.</p>
            </div>
          </div>

          <!-- Step 2 -->
          <div class="flex gap-6 md:gap-8 items-start group">
            <div class="relative z-10 w-16 h-16 md:w-20 md:h-20 rounded-2xl bg-primary/10 dark:bg-primary/5 border border-primary/20 flex items-center justify-center shrink-0 group-hover:bg-primary/20 transition-colors duration-300">
              <Sparkles className="w-7 h-7 md:w-8 md:h-8 text-primary" />
            </div>
            <div class="pt-2 md:pt-4">
              <h3 class="text-xl font-bold mb-2">Eddator processes everything</h3>
              <p class="text-muted-foreground leading-relaxed">It transcribes audio, identifies what happened, extracts NPCs, locations, and events, and drafts a session write-up.</p>
            </div>
          </div>

          <!-- Step 3 -->
          <div class="flex gap-6 md:gap-8 items-start group">
            <div class="relative z-10 w-16 h-16 md:w-20 md:h-20 rounded-2xl bg-primary/10 dark:bg-primary/5 border border-primary/20 flex items-center justify-center shrink-0 group-hover:bg-primary/20 transition-colors duration-300">
              <ScrollText className="w-7 h-7 md:w-8 md:h-8 text-primary" />
            </div>
            <div class="pt-2 md:pt-4">
              <h3 class="text-xl font-bold mb-2">You get a list of proposals</h3>
              <p class="text-muted-foreground leading-relaxed">"I found 3 new NPCs. Kael frequents the Rusty Anchor. Tormund appears to be dead. Here's a draft of what happened."</p>
            </div>
          </div>

          <!-- Step 4 -->
          <div class="flex gap-6 md:gap-8 items-start group">
            <div class="relative z-10 w-16 h-16 md:w-20 md:h-20 rounded-2xl bg-primary/10 dark:bg-primary/5 border border-primary/20 flex items-center justify-center shrink-0 group-hover:bg-primary/20 transition-colors duration-300">
              <CheckCircle className="w-7 h-7 md:w-8 md:h-8 text-primary" />
            </div>
            <div class="pt-2 md:pt-4">
              <h3 class="text-xl font-bold mb-2">Review and approve</h3>
              <p class="text-muted-foreground leading-relaxed">Accept what looks right, tweak what's close, skip what you don't care about. The AI never changes your world without your say-so.</p>
            </div>
          </div>

          <!-- Step 5 -->
          <div class="flex gap-6 md:gap-8 items-start group">
            <div class="relative z-10 w-16 h-16 md:w-20 md:h-20 rounded-2xl bg-primary/10 dark:bg-primary/5 border border-primary/20 flex items-center justify-center shrink-0 group-hover:bg-primary/20 transition-colors duration-300">
              <BookOpen className="w-7 h-7 md:w-8 md:h-8 text-primary" />
            </div>
            <div class="pt-2 md:pt-4">
              <h3 class="text-xl font-bold mb-2">Done. Your wiki just grew.</h3>
              <p class="text-muted-foreground leading-relaxed">15 minutes instead of hours. Everything linked, searchable, and ready for next session's prep.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- ═══════════════════════════════════════════ -->
  <!-- YOUR CAMPAIGN WIKI                          -->
  <!-- ═══════════════════════════════════════════ -->
  <Section class="py-24 md:py-32 bg-foreground/[0.02]">
    <div class="max-w-5xl mx-auto">
      <h2 class="font-display text-3xl md:text-4xl font-bold text-center mb-4">A Wiki That Grows From Play</h2>
      <p class="text-center text-muted-foreground text-lg mb-16 max-w-2xl mx-auto">
        Every session adds detail. An NPC can start as a name mentioned once and grow into a fully realized character over time.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Sessions -->
        <div class="wiki-card p-8 rounded-2xl border border-foreground/5 dark:border-foreground/10 hover:border-primary/20 transition-all duration-300 bg-background relative">
          <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mb-5">
            <ScrollText className="w-6 h-6 text-primary" />
          </div>
          <h3 class="text-xl font-bold mb-3">Sessions</h3>
          <p class="text-muted-foreground leading-relaxed">Write-ups of what happened each time you played, organized chronologically. The living history of your campaign.</p>
        </div>

        <!-- Things -->
        <div class="wiki-card p-8 rounded-2xl border border-foreground/5 dark:border-foreground/10 hover:border-primary/20 transition-all duration-300 bg-background relative">
          <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mb-5">
            <Users className="w-6 h-6 text-primary" />
          </div>
          <h3 class="text-xl font-bold mb-3">Things</h3>
          <p class="text-muted-foreground leading-relaxed">Every entity in your world: NPCs, locations, items, factions, monsters, lore. Each one has its own page that accumulates detail over time.</p>
        </div>

        <!-- Connections -->
        <div class="wiki-card p-8 rounded-2xl border border-foreground/5 dark:border-foreground/10 hover:border-primary/20 transition-all duration-300 bg-background relative">
          <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mb-5">
            <Link2 className="w-6 h-6 text-primary" />
          </div>
          <h3 class="text-xl font-bold mb-3">Connections</h3>
          <p class="text-muted-foreground leading-relaxed">How things relate: "Kael frequents the Rusty Anchor," "The Silver Compact is allied with the Crown of Ashenmoor." A living graph of your world.</p>
        </div>

        <!-- Player Visibility -->
        <div class="wiki-card p-8 rounded-2xl border border-foreground/5 dark:border-foreground/10 hover:border-primary/20 transition-all duration-300 bg-background relative">
          <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center mb-5">
            <Eye className="w-6 h-6 text-primary" />
          </div>
          <h3 class="text-xl font-bold mb-3">Player Visibility</h3>
          <p class="text-muted-foreground leading-relaxed">You control what players see. Secret notes stay secret. The Good Cleric's dark patron remains hidden until you're ready to reveal it.</p>
        </div>
      </div>
    </div>
  </Section>

  <!-- ═══════════════════════════════════════════ -->
  <!-- WHAT MAKES IT DIFFERENT                     -->
  <!-- ═══════════════════════════════════════════ -->
  <Section class="py-24 md:py-32">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-display text-3xl md:text-4xl font-bold text-center mb-16">Built for How GMs Actually Work</h2>

      <div class="space-y-16">
        <!-- Meets you where you are -->
        <div class="flex flex-col md:flex-row gap-6 md:gap-10 items-start">
          <div class="w-14 h-14 rounded-2xl bg-primary/10 border border-primary/20 flex items-center justify-center shrink-0">
            <MapPin className="w-7 h-7 text-primary" />
          </div>
          <div>
            <h3 class="text-xl font-bold mb-3">It meets you where you are</h3>
            <p class="text-muted-foreground leading-relaxed text-lg">You don't have to build a wiki before session 1. An NPC can start as nothing more than a name mentioned once in a session, and grow into a fully detailed character over time as they keep showing up.</p>
          </div>
        </div>

        <!-- Tolerant of neglect -->
        <div class="flex flex-col md:flex-row gap-6 md:gap-10 items-start">
          <div class="w-14 h-14 rounded-2xl bg-primary/10 border border-primary/20 flex items-center justify-center shrink-0">
            <Clock className="w-7 h-7 text-primary" />
          </div>
          <div>
            <h3 class="text-xl font-bold mb-3">Tolerant of neglect</h3>
            <p class="text-muted-foreground leading-relaxed text-lg">Skip a week of reviews? That's fine. Unreviewed suggestions expire quietly. The system never buries you under an infinite pile of homework.</p>
          </div>
        </div>

        <!-- AI proposes, you decide -->
        <div class="flex flex-col md:flex-row gap-6 md:gap-10 items-start">
          <div class="w-14 h-14 rounded-2xl bg-primary/10 border border-primary/20 flex items-center justify-center shrink-0">
            <MessageSquare className="w-7 h-7 text-primary" />
          </div>
          <div>
            <h3 class="text-xl font-bold mb-3">The AI proposes, you decide</h3>
            <p class="text-muted-foreground leading-relaxed text-lg">The AI never changes your world on its own. Every suggestion needs your approval, and every suggestion comes with reasoning so you can see why it was proposed.</p>
          </div>
        </div>

        <!-- Captures the mess -->
        <div class="flex flex-col md:flex-row gap-6 md:gap-10 items-start">
          <div class="w-14 h-14 rounded-2xl bg-primary/10 border border-primary/20 flex items-center justify-center shrink-0">
            <Swords className="w-7 h-7 text-primary" />
          </div>
          <div>
            <h3 class="text-xl font-bold mb-3">It captures the mess</h3>
            <p class="text-muted-foreground leading-relaxed text-lg">Retconned something? No problem. Mark things as "established in play but since retconned." The history is preserved, but Eddator stops treating it as current. Your campaign's contradictions are part of the story.</p>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- ═══════════════════════════════════════════ -->
  <!-- SELF-HOSTING + OPEN SOURCE                  -->
  <!-- ═══════════════════════════════════════════ -->
  <Section class="py-20 md:py-24 bg-foreground/[0.02]">
    <div class="max-w-3xl mx-auto text-center">
      <div class="inline-flex items-center gap-3 mb-6">
        <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center">
          <GitFork className="w-5 h-5 text-primary" />
        </div>
        <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center">
          <ShieldCheck className="w-5 h-5 text-primary" />
        </div>
      </div>
      <h2 class="font-display text-3xl md:text-4xl font-bold mb-6">Open Source. Self-Hostable.</h2>
      <p class="text-muted-foreground text-lg leading-relaxed mb-8">
        Eddator is open source. Use the hosted version to get started instantly, or run it on your own server with your own AI provider. Your campaign data is yours - we never sell it nor anything that comes from it.
      </p>
      <Button
        href="https://github.com/loreweaver-no"
        variant="secondary"
        class="px-8 py-4 rounded-full text-base"
        target="_blank"
        rel="noopener noreferrer"
      >
        View on GitHub
      </Button>
    </div>
  </Section>

  <!-- ═══════════════════════════════════════════ -->
  <!-- LATEST POSTS                                -->
  <!-- ═══════════════════════════════════════════ -->
  <LatestPosts count={3} />

  <!-- ═══════════════════════════════════════════ -->
  <!-- CTA                                         -->
  <!-- ═══════════════════════════════════════════ -->
  <Section class="py-24 md:py-32 relative overflow-hidden">
    <!-- CTA warm glow (warmest spot on the page) -->
    <div class="absolute inset-0 z-0 pointer-events-none">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] bg-primary/10 rounded-full blur-[140px]"></div>
    </div>

    <div class="max-w-3xl mx-auto text-center relative z-10">
      <h2 class="font-display text-3xl md:text-5xl font-bold mb-6">
        Come sit by our fire.<br />
        <span class="text-primary">Tell us your story.</span>
      </h2>
      <p class="text-muted-foreground text-lg mb-10 max-w-xl mx-auto">
        Eddator is in early development. Subscribe to hear when we set sail.
      </p>
      <NewsletterSignup lang={lang} variant="hero" />
      <p class="mt-8">
        <a
          href="https://github.com/loreweaver-no"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-muted-foreground hover:text-foreground transition-colors"
        >
          View on GitHub
        </a>
      </p>
    </div>
  </Section>

<!-- Page-level: warm center + frost edges -->
<div class="fixed inset-0 z-[-1] pointer-events-none page-atmosphere"></div>

<style>
  /* Hero fade-up */
  .hero-content {
    animation: fadeUp 0.8s ease-out forwards;
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ── Frost on the edges ── */
  /* The cold trying to creep in from outside the cottage */
  .frost-edges {
    background:
      /* Left frost */
      linear-gradient(to right,
        rgba(45, 70, 105, 0.35) 0%,
        rgba(45, 70, 105, 0.12) 8%,
        transparent 22%),
      /* Right frost */
      linear-gradient(to left,
        rgba(45, 70, 105, 0.35) 0%,
        rgba(45, 70, 105, 0.12) 8%,
        transparent 22%),
      /* Top frost */
      linear-gradient(to bottom,
        rgba(45, 70, 105, 0.25) 0%,
        rgba(45, 70, 105, 0.08) 6%,
        transparent 18%),
      /* Bottom frost */
      linear-gradient(to top,
        rgba(45, 70, 105, 0.20) 0%,
        rgba(45, 70, 105, 0.06) 5%,
        transparent 15%);
  }

  /* Less intense frost in light mode */
  :root .frost-edges {
    background:
      linear-gradient(to right,
        rgba(45, 70, 105, 0.10) 0%,
        rgba(45, 70, 105, 0.04) 8%,
        transparent 18%),
      linear-gradient(to left,
        rgba(45, 70, 105, 0.10) 0%,
        rgba(45, 70, 105, 0.04) 8%,
        transparent 18%),
      linear-gradient(to bottom,
        rgba(45, 70, 105, 0.08) 0%,
        transparent 12%),
      linear-gradient(to top,
        rgba(45, 70, 105, 0.06) 0%,
        transparent 10%);
  }

  :root:where(.dark) .frost-edges {
    background:
      linear-gradient(to right,
        rgba(45, 70, 105, 0.35) 0%,
        rgba(45, 70, 105, 0.12) 8%,
        transparent 22%),
      linear-gradient(to left,
        rgba(45, 70, 105, 0.35) 0%,
        rgba(45, 70, 105, 0.12) 8%,
        transparent 22%),
      linear-gradient(to bottom,
        rgba(45, 70, 105, 0.25) 0%,
        rgba(45, 70, 105, 0.08) 6%,
        transparent 18%),
      linear-gradient(to top,
        rgba(45, 70, 105, 0.20) 0%,
        rgba(45, 70, 105, 0.06) 5%,
        transparent 15%);
  }

  /* ── Page-level atmosphere ── */
  /* Frost on edges + warm glow at center, applied to entire page */
  .page-atmosphere {
    background:
      /* Warm center */
      radial-gradient(ellipse 60% 45% at 50% 50%,
        rgba(224, 122, 58, 0.06) 0%,
        transparent 70%),
      /* Frost left */
      linear-gradient(to right,
        rgba(45, 70, 105, 0.20) 0%,
        rgba(45, 70, 105, 0.06) 5%,
        transparent 15%),
      /* Frost right */
      linear-gradient(to left,
        rgba(45, 70, 105, 0.20) 0%,
        rgba(45, 70, 105, 0.06) 5%,
        transparent 15%);
  }

  :root .page-atmosphere {
    background:
      radial-gradient(ellipse 60% 45% at 50% 50%,
        rgba(224, 122, 58, 0.04) 0%,
        transparent 70%),
      linear-gradient(to right,
        rgba(45, 70, 105, 0.06) 0%,
        transparent 12%),
      linear-gradient(to left,
        rgba(45, 70, 105, 0.06) 0%,
        transparent 12%);
  }

  :root:where(.dark) .page-atmosphere {
    background:
      radial-gradient(ellipse 60% 45% at 50% 50%,
        rgba(224, 122, 58, 0.06) 0%,
        transparent 70%),
      linear-gradient(to right,
        rgba(45, 70, 105, 0.20) 0%,
        rgba(45, 70, 105, 0.06) 5%,
        transparent 15%),
      linear-gradient(to left,
        rgba(45, 70, 105, 0.20) 0%,
        rgba(45, 70, 105, 0.06) 5%,
        transparent 15%);
  }

  /* ── Fire flicker ── */
  /* Three overlapping glows with different flicker rhythms.
     Real fire doesn't breathe smoothly -- it dances. */
  .fire-core {
    background: rgba(224, 122, 58, 0.22);
    animation: flickerCore 3s ease-in-out infinite;
  }

  .fire-secondary {
    background: rgba(240, 160, 80, 0.14);
    animation: flickerSecondary 2.3s ease-in-out infinite;
    animation-delay: -0.8s;
  }

  .fire-accent {
    background: rgba(255, 180, 100, 0.10);
    animation: flickerAccent 1.8s ease-in-out infinite;
    animation-delay: -1.4s;
  }

  @keyframes flickerCore {
    0%   { opacity: 0.8; transform: scale(1); }
    10%  { opacity: 0.65; transform: scale(0.98); }
    20%  { opacity: 0.9; transform: scale(1.01); }
    35%  { opacity: 0.7; transform: scale(0.99); }
    50%  { opacity: 0.95; transform: scale(1.02); }
    65%  { opacity: 0.75; transform: scale(0.97); }
    80%  { opacity: 0.85; transform: scale(1.01); }
    90%  { opacity: 0.7; transform: scale(0.99); }
    100% { opacity: 0.8; transform: scale(1); }
  }

  @keyframes flickerSecondary {
    0%   { opacity: 0.7; transform: scale(1) translateX(0); }
    15%  { opacity: 0.9; transform: scale(1.03) translateX(5px); }
    30%  { opacity: 0.6; transform: scale(0.97) translateX(-3px); }
    50%  { opacity: 0.85; transform: scale(1.01) translateX(2px); }
    70%  { opacity: 0.65; transform: scale(0.98) translateX(-4px); }
    85%  { opacity: 0.8; transform: scale(1.02) translateX(3px); }
    100% { opacity: 0.7; transform: scale(1) translateX(0); }
  }

  @keyframes flickerAccent {
    0%   { opacity: 0.6; transform: scale(1) translateY(0); }
    12%  { opacity: 0.85; transform: scale(1.04) translateY(-4px); }
    25%  { opacity: 0.5; transform: scale(0.96) translateY(2px); }
    40%  { opacity: 0.9; transform: scale(1.02) translateY(-3px); }
    55%  { opacity: 0.55; transform: scale(0.98) translateY(1px); }
    70%  { opacity: 0.8; transform: scale(1.03) translateY(-5px); }
    85%  { opacity: 0.6; transform: scale(0.97) translateY(2px); }
    100% { opacity: 0.6; transform: scale(1) translateY(0); }
  }

  /* ── Ember particles (CSS-only, zero JS) ── */
  .ember-field::before,
  .ember-field::after {
    content: '';
    position: absolute;
    width: 2px;
    height: 2px;
    border-radius: 50%;
    background: transparent;
  }

  .ember-field::before {
    box-shadow:
      120px 350px 2px 0 rgba(240, 147, 78, 0.6),
      380px 180px 1px 0 rgba(240, 147, 78, 0.4),
      620px 420px 2px 0 rgba(240, 147, 78, 0.35),
      260px 520px 1px 0 rgba(240, 147, 78, 0.5),
      780px 280px 2px 0 rgba(240, 147, 78, 0.3),
      510px 120px 1px 0 rgba(240, 147, 78, 0.45),
      85px 460px 2px 0 rgba(240, 147, 78, 0.35),
      670px 370px 1px 0 rgba(240, 147, 78, 0.5),
      200px 220px 2px 0 rgba(240, 147, 78, 0.25),
      880px 480px 1px 0 rgba(240, 147, 78, 0.4),
      440px 90px 1px 0 rgba(240, 147, 78, 0.3),
      730px 550px 2px 0 rgba(240, 147, 78, 0.35);
    animation: emberDrift1 16s ease-in-out infinite;
  }

  .ember-field::after {
