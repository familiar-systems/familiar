---
import { languages, defaultLang } from '~/i18n/ui';
import Layout from '~/layouts/Layout.astro';
import HomePage from '~/components/pages/HomePage.astro';

export async function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang = defaultLang } = Astro.params;
---

<Layout
  title="Loreweaver - AI-Assisted Campaign Notebook"
  description="Capture your tabletop RPG sessions and build a living campaign wiki, automatically. You run the game. Loreweaver takes notes."
>
  <HomePage lang={lang} />
</Layout>
