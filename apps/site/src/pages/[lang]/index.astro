---
import { languages, defaultLang } from '~/i18n/ui';
import Layout from '~/layouts/Layout.astro';
import HomePage from '~/components/pages/HomePage.astro';

export async function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang = defaultLang } = Astro.params;
---

<Layout
  title="familiar.systems - AI-Assisted Campaign Notebook"
  description="You run the game. Your familiar remembers it. An AI-assisted campaign notebook for tabletop RPG game masters."
>
  <HomePage lang={lang} />
</Layout>
