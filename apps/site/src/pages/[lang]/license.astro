---
import UntranslatedLayout from '~/layouts/UntranslatedLayout.astro';
import { siteConfig } from '~/site.config';
import { languages } from '~/i18n/ui';

export async function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}
---

<UntranslatedLayout title="License - familiar.systems" description="familiar.systems is licensed under the GNU Affero General Public License v3.0 (AGPL-3.0).">
    <div class="pt-32 pb-24">
        <div class="max-w-4xl mx-auto px-6">
            <h1 class="text-4xl md:text-5xl font-bold mb-8">License</h1>
            <div class="prose dark:prose-invert max-w-none text-foreground/80">
                <p class="text-lg mb-6">
                    familiar.systems is licensed under the
                    <a href="https://www.gnu.org/licenses/agpl-3.0.html" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">GNU Affero General Public License v3.0 (AGPL-3.0)</a>.
                </p>

                <h2 class="text-2xl font-bold mt-12 mb-4 text-foreground">What does that mean?</h2>

                <div class="p-6 bg-foreground/5 rounded-xl border border-foreground/10 my-8 space-y-4">
                    <div class="flex items-start gap-3">
                        <span class="text-green-500 font-bold text-lg leading-6">&#10003;</span>
                        <div>
                            <strong class="text-foreground">True open source: use, study, modify, distribute.</strong>
                            <p class="mt-1 text-sm">familiar.systems is OSI-approved free software. You can use it for any purpose, read the source, make changes, and distribute copies.</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-3">
                        <span class="text-green-500 font-bold text-lg leading-6">&#10003;</span>
                        <div>
                            <strong class="text-foreground">Self-host freely.</strong>
                            <p class="mt-1 text-sm">Run familiar.systems on your own infrastructure with no restrictions. Your campaign data stays yours.</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-3">
                        <span class="text-green-500 font-bold text-lg leading-6">&#10003;</span>
                        <div>
                            <strong class="text-foreground">Fork and contribute.</strong>
                            <p class="mt-1 text-sm">Community contributions are welcome. Fork the project, build on it, and submit improvements back.</p>
                        </div>
                    </div>
                    <div class="flex items-start gap-3">
                        <span class="text-amber-500 font-bold text-lg leading-6">&#9888;</span>
                        <div>
                            <strong class="text-foreground">Share modifications under AGPL.</strong>
                            <p class="mt-1 text-sm">If you distribute a modified version or offer it as a network service, you must make the complete source code available under the same AGPL-3.0 license. This includes modifications made to code running on a server that users interact with over a network.</p>
                        </div>
                    </div>
                </div>

                <h2 class="text-2xl font-bold mt-12 mb-4 text-foreground">Why this license?</h2>
                <p>
                    We believe campaign tools should be open source. The AGPL ensures that familiar.systems and any improvements to it remain free for everyone. You can self-host, fork, compete, and build on this project without restriction.
                </p>
                <p>
                    The copyleft obligation means that if someone modifies familiar.systems and offers it as a service, those improvements flow back to the community. This prevents proprietary forks without limiting what anyone can do with the software.
                </p>

                <h2 class="text-2xl font-bold mt-12 mb-4 text-foreground">Full license text</h2>
                <p>
                    The full text of the AGPL-3.0 license is available at
                    <a href="https://www.gnu.org/licenses/agpl-3.0.html" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">gnu.org</a>
                    and in the
                    <a href="https://github.com/familiar-systems" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">familiar.systems repository</a>.
                </p>

                <h2 class="text-2xl font-bold mt-12 mb-4 text-foreground">Questions?</h2>
                <p>
                    If you have questions about what the license allows, reach us at
                    <a href={`mailto:${siteConfig.contact?.email?.support}`} class="text-primary hover:underline">{siteConfig.contact?.email?.support}</a>.
                </p>
            </div>
        </div>
    </div>
</UntranslatedLayout>
