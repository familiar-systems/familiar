---
import UntranslatedLayout from '~/layouts/UntranslatedLayout.astro';
import Button from '~/components/ui/Button.astro';
import { languages, defaultLang } from '~/i18n/ui';
import { Mail } from 'lucide-react';

export async function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}
---

<UntranslatedLayout
  title="Check Your Inbox - familiar.systems"
  description="Confirm your newsletter subscription."
>
  <div class="min-h-[70vh] flex items-center justify-center">
    <div class="max-w-lg mx-auto px-6 text-center">
      <div
        class="w-16 h-16 rounded-2xl bg-primary/10 border border-primary/20 flex items-center justify-center mx-auto mb-8"
      >
        <Mail className="w-8 h-8 text-primary" />
      </div>
      <h1 class="font-display text-3xl md:text-4xl font-bold mb-4">
        Check your inbox
      </h1>
      <p class="text-lg text-muted-foreground leading-relaxed mb-10">
        We've sent you a confirmation email. Click the link inside to confirm
        your subscription and start receiving updates.
      </p>
      <Button
        href={`/${defaultLang}/`}
        variant="secondary"
        class="px-8 py-3 rounded-full text-base"
      >
        Back to home
      </Button>
    </div>
  </div>
</UntranslatedLayout>
