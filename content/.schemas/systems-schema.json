{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "systems-schema.json",
  "type": "object",
  "required": ["systems"],
  "additionalProperties": false,
  "properties": {
    "systems": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "tagline", "color", "bundle"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "name": { "$ref": "#/definitions/LocalizedString" },
          "tagline": { "$ref": "#/definitions/LocalizedString" },
          "color": {
            "type": "string",
            "pattern": "^#[0-9A-Fa-f]{6}$"
          },
          "popular": { "type": "boolean" },
          "bundle": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9-]+/[a-z0-9-]+$"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "LocalizedString": {
      "type": "object",
      "required": ["en"],
      "patternProperties": {
        "^[a-z]{2}(-[A-Z]{2})?$": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
