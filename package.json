{
  "name": "familiar-systems",
  "private": true,
  "scripts": {
    "lint": "pnpm -r run lint",
    "format": "pnpm -r run format",
    "format:check": "pnpm -r run format:check",
    "typecheck": "pnpm -r run typecheck",
    "build:web": "pnpm --filter @familiar-systems/web build",
    "build:site": "pnpm --filter @familiar-systems/site build",
    "test": "vitest run --passWithNoTests"
  },
  "devDependencies": {
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "typescript": "catalog:",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "overrides": {
      "vite": "^7"
    }
  }
}
