{
  "openapi": "3.1.0",
  "info": {
    "title": "familiar.systems campaign API",
    "description": "Campaign-scoped endpoints: catalog, metadata, and (future) CRDT room bootstrapping.",
    "license": {
      "name": "AGPL-3.0-or-later",
      "identifier": "AGPL-3.0-or-later"
    },
    "version": "0.1.0"
  },
  "paths": {
    "/campaign/{id}": {
      "get": {
        "tags": ["campaign"],
        "operationId": "get_campaign",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Campaign ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Campaign metadata",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CampaignMetadataResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid session"
          },
          "403": {
            "description": "Not the campaign owner"
          },
          "404": {
            "description": "Campaign not on this shard"
          },
          "500": {
            "description": "Internal error"
          },
          "503": {
            "description": "Server restarting"
          }
        }
      },
      "patch": {
        "tags": ["campaign"],
        "operationId": "patch_campaign",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Campaign ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PatchCampaignRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Campaign updated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CampaignMetadataResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid session"
          },
          "403": {
            "description": "Not the campaign owner"
          },
          "404": {
            "description": "Campaign not on this shard"
          },
          "409": {
            "description": "Wizard already completed"
          },
          "422": {
            "description": "Required fields missing for wizard completion"
          },
          "500": {
            "description": "Update failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CampaignErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/campaign/{id}/pages": {
      "post": {
        "tags": ["pages"],
        "operationId": "create_page",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Campaign ID",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePageRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Page created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PageResponse"
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid session"
          },
          "403": {
            "description": "Caller is not a GM of this campaign"
          },
          "404": {
            "description": "Campaign not on this shard"
          },
          "409": {
            "description": "Another page of the same kind already uses this name"
          },
          "422": {
            "description": "Parent page not found, or the page name is empty"
          },
          "500": {
            "description": "Creation failed"
          },
          "501": {
            "description": "Creating an entity from a template is not yet supported"
          },
          "503": {
            "description": "Server restarting or platform unreachable"
          }
        }
      }
    },
    "/catalog/systems": {
      "get": {
        "tags": ["catalog"],
        "operationId": "list_systems",
        "parameters": [
          {
            "name": "locale",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Locale-resolved game system catalog",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CatalogResponse"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "tags": ["health"],
        "summary": "Readiness-style health endpoint. Returns 200 with `ready` body while\nthe registry is in `Phase::Ready`; once drain has begun, returns 503\nwith `draining`. k8s readiness probes consume the status code to\ntake the pod out of the LB rotation immediately when drain starts,\nso the platform's `/internal/campaign/init` calls stop being routed\nhere before in-flight requests finish. If the registry itself is\nunreachable (mailbox closed or actor crashed), returns 503 with\n`registry_unavailable`.",
        "operationId": "health",
        "responses": {
          "200": {
            "description": "Ready"
          },
          "503": {
            "description": "Draining or unavailable"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AudioMode": {
        "type": "string",
        "description": "Audio capture / training mode chosen during the wizard.\n\nThree states modeled as a sum type, not a `bool` pair, so the FE\ncan't accidentally produce \"no recording but train on it\" or other\nnonsense combinations.",
        "enum": ["opt-in", "opt-out", "text-only"]
      },
      "ByoEntry": {
        "type": "object",
        "required": ["bundle"],
        "properties": {
          "bundle": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TemplateRef"
            },
            "description": "Default template bundle when BYO is selected. The BYO card's\ndisplay copy (title, body, empty-input fallback, swatch color)\nlives in the wizard frontend alongside the rest of the wizard's\nUI strings; only the bundle is catalog-maintainer configuration,\nso only the bundle ships through this struct."
          }
        }
      },
      "CampaignErrorResponse": {
        "type": "object",
        "required": ["error", "campaign_id"],
        "properties": {
          "campaign_id": {
            "type": "string"
          },
          "error": {
            "type": "string"
          }
        }
      },
      "CampaignMetadataResponse": {
        "type": "object",
        "required": ["campaign_id", "name", "created_at", "updated_at"],
        "properties": {
          "campaign_id": {
            "type": "string"
          },
          "content_locale": {
            "type": ["string", "null"]
          },
          "created_at": {
            "type": "string"
          },
          "game_system": {
            "type": ["string", "null"]
          },
          "home_page_id": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/PageId",
                "description": "The campaign's home / landing-page Page (\"Campaign Base Camp\"), seeded\nat creation. The client opens this as the campaign's home base. Absent\nonly in the brief window before the async seed completes."
              }
            ]
          },
          "name": {
            "type": "string"
          },
          "tagline": {
            "type": ["string", "null"]
          },
          "updated_at": {
            "type": "string"
          },
          "wizard_completed_at": {
            "type": ["string", "null"],
            "description": "ISO 8601 timestamp, present once the wizard has been completed."
          }
        }
      },
      "CatalogResponse": {
        "type": "object",
        "required": ["systems", "byo"],
        "properties": {
          "byo": {
            "$ref": "#/components/schemas/ByoEntry",
            "description": "The \"bring your own\" affordance: a single always-visible card\nrendered below the catalog list. Not a system itself; the wizard\nresolves its display copy and default template bundle from this."
          },
          "systems": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SystemEntry"
            }
          }
        }
      },
      "CreateEntityBody": {
        "type": "object",
        "description": "Body for creating an `entity` page (authored world content - an NPC, a\nlocation, a bit of lore). `name` is required.",
        "required": ["name"],
        "properties": {
          "from_template_id": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/PageId",
                "description": "Template to clone from. Not yet supported; a value here yields 501."
              }
            ]
          },
          "name": {
            "type": "string"
          },
          "parent": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/PageId",
                "description": "Parent Page to nest under in the table of contents. `None` => ToC root.\nFIXME this should probably the ID of the ToC block and not a `PageId`.\nThis would let us nest pages under, say, a Folder."
              }
            ]
          },
          "status": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/Status"
              }
            ]
          }
        }
      },
      "CreatePageRequest": {
        "oneOf": [
          {
            "type": "object",
            "required": ["content", "kind"],
            "properties": {
              "content": {
                "$ref": "#/components/schemas/CreateEntityBody"
              },
              "kind": {
                "type": "string",
                "enum": ["entity"]
              }
            }
          },
          {
            "type": "object",
            "required": ["content", "kind"],
            "properties": {
              "content": {
                "$ref": "#/components/schemas/CreateTemplateBody"
              },
              "kind": {
                "type": "string",
                "enum": ["template"]
              }
            }
          },
          {
            "type": "object",
            "required": ["content", "kind"],
            "properties": {
              "content": {
                "$ref": "#/components/schemas/CreateSessionBody"
              },
              "kind": {
                "type": "string",
                "enum": ["session"]
              }
            }
          }
        ],
        "description": "Create a new Page in a campaign, discriminated by `kind`. The wire shape is\n`{ \"kind\": \"entity\" | \"template\" | \"session\", \"content\": { ... } }`.\n\nA missing `status` defaults to `gmOnly` (the domain default for new content).\n`parent` places the Page in the table of contents: omitted appends it at the\nToC root; `Some(id)` nests it as the last child of that Page's ToC node."
      },
      "CreateSessionBody": {
        "type": "object",
        "description": "Body for creating a `session` page - its document plus its temporal record,\nminted together in one genesis transaction.\n\n`name` is required and non-blank, like every other page kind, and unique among\nsessions (\"The End of Perth\"). The client renders `Session {ordinal}: {name}`\nfrom the response's `ordinal` and `name`.",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string"
          },
          "parent": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/PageId",
                "description": "Parent to nest under in the table of contents. `None` => ToC root."
              }
            ]
          },
          "status": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/Status"
              }
            ]
          }
        }
      },
      "CreateTemplateBody": {
        "type": "object",
        "description": "Body for creating a `template` page - the prototype other entities clone\nfrom. A template never clones from another template, so it carries no\n`from_template_id`. `name` is required.",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string"
          },
          "parent": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/PageId",
                "description": "Parent Page to nest under in the table of contents. `None` => ToC root."
              }
            ]
          },
          "status": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/Status"
              }
            ]
          }
        }
      },
      "EntityResponse": {
        "type": "object",
        "description": "A created `entity` page.",
        "required": ["id", "name", "status", "created_at", "updated_at"],
        "properties": {
          "created_at": {
            "type": "string",
            "description": "RFC 3339 timestamp."
          },
          "id": {
            "$ref": "#/components/schemas/PageId"
          },
          "name": {
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/Status"
          },
          "template_id": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/PageId",
                "description": "Lineage: the template this entity was cloned from, if any."
              }
            ]
          },
          "updated_at": {
            "type": "string",
            "description": "RFC 3339 timestamp."
          }
        }
      },
      "PageId": {
        "type": "string",
        "format": "ulid",
        "description": "Uniquely identifies a page (NPC, location, item, etc.).\nULID for compact URLs (26 chars) and B-tree-friendly insert ordering."
      },
      "PageResponse": {
        "oneOf": [
          {
            "type": "object",
            "required": ["content", "kind"],
            "properties": {
              "content": {
                "$ref": "#/components/schemas/EntityResponse"
              },
              "kind": {
                "type": "string",
                "enum": ["entity"]
              }
            }
          },
          {
            "type": "object",
            "required": ["content", "kind"],
            "properties": {
              "content": {
                "$ref": "#/components/schemas/TemplateResponse"
              },
              "kind": {
                "type": "string",
                "enum": ["template"]
              }
            }
          },
          {
            "type": "object",
            "required": ["content", "kind"],
            "properties": {
              "content": {
                "$ref": "#/components/schemas/SessionResponse"
              },
              "kind": {
                "type": "string",
                "enum": ["session"]
              }
            }
          }
        ],
        "description": "A created Page, returned with `201 Created`, discriminated by `kind`. The\nwire shape mirrors the request: `{ \"kind\": \"...\", \"content\": { ... } }`."
      },
      "PatchCampaignRequest": {
        "type": "object",
        "properties": {
          "audio": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/AudioMode"
              }
            ]
          },
          "content_locale": {
            "type": ["string", "null"],
            "description": "BCP-47 language tag for the campaign's content (sticky once set)."
          },
          "evals_enabled": {
            "type": ["boolean", "null"]
          },
          "game_system": {
            "type": ["string", "null"],
            "description": "Opaque display label for the campaign's game system. The wizard\nresolves a single string at submission: catalog pick uses the\nlocale-resolved `name`; BYO uses the typed name or the catalog's\n`byo.default_name`. Both tiers treat this as an opaque label."
          },
          "name": {
            "type": ["string", "null"]
          },
          "tagline": {
            "type": ["string", "null"]
          },
          "template_slugs": {
            "type": ["array", "null"],
            "items": {
              "type": "string"
            },
            "description": "Bundle slugs the GM picked. Deduped client-side."
          },
          "wizard_complete": {
            "type": "boolean",
            "description": "When true, validates all required fields are present and sets\n`wizard_completed_at`. Returns 409 if the wizard was already\ncompleted. Subsequent PATCHes without this flag update metadata\nwithout touching the wizard timestamp."
          }
        }
      },
      "SessionId": {
        "type": "string",
        "format": "ulid",
        "description": "Identifies a play session (discord call, table session, etc.)."
      },
      "SessionResponse": {
        "type": "object",
        "description": "A created `session`: its page plus its temporal record.\n\nThe display name is `Session {ordinal}` (plus `: {name}` when the GM named\nit); the client composes it from `ordinal` and the page title (`name`).",
        "required": ["page_id", "session_id", "ordinal", "name", "created_at"],
        "properties": {
          "created_at": {
            "type": "string",
            "description": "RFC 3339 timestamp (the session's recording time)."
          },
          "name": {
            "type": "string",
            "description": "The session's label: its page title (required and unique among sessions)."
          },
          "ordinal": {
            "type": "integer",
            "format": "int64",
            "description": "The GM-curated sequence number (\"Session N\"). Serialized as a JSON number\n(session counts are small); `#[ts(type)]` keeps the TS type `number`\nrather than ts-rs's default `bigint` for `i64`."
          },
          "page_id": {
            "$ref": "#/components/schemas/PageId",
            "description": "The Session page (its document, at `/p/{page_id}`)."
          },
          "session_id": {
            "$ref": "#/components/schemas/SessionId",
            "description": "The temporal record - the durable identity relationships reference."
          }
        }
      },
      "Status": {
        "type": "string",
        "description": "Visibility status for campaign content. The CRDT syncs all content to all\nclients regardless of status; consumers (the browser UI, AI conversations)\nfilter what they surface based on the user's role.\nSee: docs/plans/2026-02-22-ai-prd.md",
        "enum": ["gmOnly", "known", "retconned"]
      },
      "SystemEntry": {
        "type": "object",
        "required": ["id", "name", "tagline", "color", "popular", "bundle"],
        "properties": {
          "bundle": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TemplateRef"
            }
          },
          "color": {
            "type": "string",
            "description": "Hex color (`#rrggbb`) used by the wizard's system picker."
          },
          "id": {
            "type": "string",
            "description": "Slug, kebab-case. Stable across locales."
          },
          "name": {
            "type": "string"
          },
          "popular": {
            "type": "boolean"
          },
          "tagline": {
            "type": "string"
          }
        }
      },
      "TemplateRef": {
        "type": "object",
        "required": ["slug", "name", "description", "icon"],
        "properties": {
          "description": {
            "type": "string"
          },
          "icon": {
            "type": "string",
            "description": "`lucide-react` icon name."
          },
          "name": {
            "type": "string"
          },
          "slug": {
            "type": "string",
            "description": "`<system-id>/<template-name>` slug, e.g. `common/npc`."
          }
        }
      },
      "TemplateResponse": {
        "type": "object",
        "description": "A created `template` page. A template has no `template_id` lineage of its own\n(it is the source, not a clone).",
        "required": ["id", "name", "status", "created_at", "updated_at"],
        "properties": {
          "created_at": {
            "type": "string",
            "description": "RFC 3339 timestamp."
          },
          "id": {
            "$ref": "#/components/schemas/PageId"
          },
          "name": {
            "type": "string"
          },
          "status": {
            "$ref": "#/components/schemas/Status"
          },
          "updated_at": {
            "type": "string",
            "description": "RFC 3339 timestamp."
          }
        }
      }
    }
  }
}
